#include <iostream>
using namespace std;

struct Node{
    int data;
    Node *left,*right;

    Node(int x){
        data=x;
        left=right=NULL;
    }
};

Node* insert(Node* root,int value){

    if(root==NULL)
        return new Node(value);

    if(value<root->data)
        root->left=insert(root->left,value);
    else
        root->right=insert(root->right,value);

    return root;
}

void inorder(Node* root){

    if(root==NULL)
        return;

    inorder(root->left);
    cout<<root->data<<" ";
    inorder(root->right);
}

int main(){

    int arr[]={5,3,8,1,4};

    Node* root=NULL;

    for(int i=0;i<5;i++)
        root=insert(root,arr[i]);

    inorder(root);

}
